{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4-project-gate.local/schemas/decision-escape-routes.v3.schema.json",
  "title": "EV4 Decision Escape Routes Wave 0 State",
  "description": "Baseline schema for Project Gate Wave 0 DECISION_ESCAPE_ROUTES.yml adoption state. This schema validates the adoption-only empty baseline shape, requires records to remain empty until a later audit wave defines full record validation, and does not claim enforcement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consumer_repo",
    "consumer_repo_evidence_state",
    "last_updated",
    "brc_reference",
    "kernel_reference",
    "records"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "consumer_repo": { "const": "EV4-Project-Gate" },
    "consumer_repo_evidence_state": { "const": "expected_unverified" },
    "last_updated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "pr", "commit"],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "pr": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] }
      }
    },
    "brc_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "profile"],
      "properties": {
        "document": { "const": "Behavioral_Rule_Coverage_v0.4.1" },
        "profile": { "const": "EV4_CONSUMER_DECISION_TRIGGER_ARCHITECTURE_v0.4.1" }
      }
    },
    "kernel_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "decision_taxonomy_version", "decision_cards_version"],
      "properties": {
        "repo": { "const": "EV4-Decision-Kernel" },
        "decision_taxonomy_version": { "type": ["string", "null"] },
        "decision_cards_version": { "type": ["string", "null"] }
      }
    },
    "records": {
      "type": "array",
      "description": "Wave 0 adoption-only baseline records must stay empty until a later audit wave defines full non-empty record validation.",
      "maxItems": 0,
      "items": {
        "type": "object",
        "not": {
          "anyOf": [
            { "required": ["resolved"] },
            { "required": ["production_ready"] }
          ]
        }
      }
    },
    "routes": false
  }
}
